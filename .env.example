# Copy this file to .env and fill in real values.

# SQLite database file (relative to the prisma/ directory)
DATABASE_URL="file:./dev.db"

# Password for the single-user login
APP_PASSWORD="pick-a-strong-password"

# Secret used to sign the session cookie. Generate with: openssl rand -hex 32
AUTH_SECRET=""

# ── AI Provider ─────────────────────────────────────────────────
# Pick ONE of these setups:
#
# OPTION 1: Ollama (FREE, local) — install from https://ollama.com
#   AI_PROVIDER="ollama"
#   AI_MODEL="llama3"            # or mistral, qwen2, gemma2, etc.
#   # No API key needed. Just run: ollama pull llama3
#
# OPTION 2: Groq (FREE tier, cloud, fast) — get key at https://console.groq.com
#   AI_PROVIDER="openai"
#   AI_BASE_URL="https://api.groq.com/openai/v1"
#   AI_API_KEY="gsk_..."
#   AI_MODEL="llama-3.3-70b-versatile"
#
# OPTION 3: OpenRouter (many models, some free) — https://openrouter.ai
#   AI_PROVIDER="openai"
#   AI_BASE_URL="https://openrouter.ai/api/v1"
#   AI_API_KEY="sk-or-..."
#   AI_MODEL="meta-llama/llama-3.3-70b-instruct:free"
#
# OPTION 4: Anthropic Claude (paid, best quality)
#   AI_PROVIDER="anthropic"
#   ANTHROPIC_API_KEY="sk-ant-..."
#
AI_PROVIDER="ollama"
AI_MODEL="llama3"
# AI_BASE_URL=                   # auto-set for ollama (localhost:11434)
# AI_API_KEY=                    # not needed for ollama

# Anthropic key (only needed if AI_PROVIDER="anthropic")
ANTHROPIC_API_KEY=""

# Job discovery API keys — required in Phase 4 for the paid/keyed sources.
# Greenhouse / Lever / Ashby public boards need no key.
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
JSEARCH_API_KEY=""
